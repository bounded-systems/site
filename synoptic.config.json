{
  "site": "bounded.tools",
  "layers": {
    "jsonld": {
      "shapes": "contract/jsonld.shapes.ttl",
      "doc": "dist"
    },
    "markdown": {
      "proseCorpus": "prose-corpus.json",
      "docCorpus": "doc-corpus.json"
    },
    "website": {
      "dist": "dist",
      "gates": [
        "a11y-heuristic-gate.mjs",
        "html-validator-gate.mjs"
      ]
    }
  },
  "graph": {
    "id": "https://bounded.tools/#org",
    "plugins": [
      "org",
      "packages",
      "lattice",
      "jargon",
      "palette"
    ],
    "bridge": [
      {
        "predicate": "sameAs",
        "id": "https://robertdelanghe.dev/#person"
      }
    ]
  },
  "build": {
    "pages": [
      {
        "id": "home",
        "route": "",
        "title": "bounded.tools",
        "sections": [
          {
            "title": "The organization",
            "query": {
              "type": "Organization"
            }
          },
          {
            "title": "The corpus",
            "query": {
              "type": "SoftwareSourceCode"
            }
          },
          {
            "title": "Contracts",
            "query": {
              "type": "Dataset"
            }
          }
        ]
      },
      {
        "id": "corpus",
        "route": "corpus",
        "title": "The corpus",
        "query": {
          "type": "SoftwareSourceCode"
        }
      }
    ],
    "theme": {
      "text": "--color-ink",
      "surface": "--color-paper",
      "accent": "--color-forest",
      "border": "--color-line",
      "font": "--font-display",
      "mono": "--font-mono"
    }
  }
}
