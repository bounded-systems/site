{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "bounded.tools navigation",
  "description": "Canonical navigation source. build.mjs renders the primary site nav (cross-page links, identical on every page) and the home-only on-page section list from this file, so the two never drift. site[] = separate pages/external; sections[] = in-page anchors (a table of contents, not site navigation).",
  "site": [
    { "@type": "SiteNavigationElement", "name": "Contracts", "url": "/contracts", "kind": "page" },
    { "@type": "SiteNavigationElement", "name": "Conformance", "url": "/conformance", "kind": "page" },
    { "@type": "SiteNavigationElement", "name": "Writing", "url": "/blog/", "kind": "page" },
    { "@type": "SiteNavigationElement", "name": "GitHub", "url": "https://github.com/bounded-systems", "kind": "external" }
  ],
  "sections": [
    { "@type": "SiteNavigationElement", "name": "The bet", "url": "#bet" },
    { "@type": "SiteNavigationElement", "name": "The model", "url": "#model" },
    { "@type": "SiteNavigationElement", "name": "Honesty", "url": "#honesty" },
    { "@type": "SiteNavigationElement", "name": "Proof", "url": "#proof" }
  ]
}
